---
import Layout from '../../layouts/Layout.astro';
import { getLocaleData } from '../../data/site-content';

const { lang } = Astro.params;
const { activeLang, locale, menu, languages } = getLocaleData(lang);
---

<Layout
  lang={activeLang}
  menu={menu}
  languages={languages}
  pageTitle={locale.pageTitle}
  navLabel={locale.ui.navLabel}
  languageLabel={locale.ui.languageLabel}
  brandTagline={locale.ui.brandTagline}
>
  <section>
    <h1>{locale.pages.home.title}</h1>
    <p>{locale.pages.home.description}</p>
    <img src="/assets/images/flyer.jpg" alt="Flyer" style="max-width: 100%; height: auto; margin-top: 1rem;" />
  </section>

  {locale.pages.home.sections.map((section) => (
    <section>
      <h2>{section.title}</h2>
      <p>{section.description}</p>
    </section>
  ))}
</Layout>