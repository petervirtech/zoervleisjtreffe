---
import Layout from '../../../layouts/Layout.astro';
import { getLocaleData } from '../../../data/site-content';

const { lang } = Astro.params;
const { activeLang, locale, menu, languages } = getLocaleData(lang);
const status = Astro.url.searchParams.get('status');

const content = {
	lim: {
		title: 'Inschrieve',
		eventTitle: '3e oape Joabiks Zoerveisjtreff',
		eventMeta: 'Datum: 4 september 2026, begin um 18:00 bie Brasserie De Maar in de wei.',
		intro: 'Vul hie de geveens in um uch aan te melde veur ’t treffe.',
		firstName: 'Voornaam',
		lastName: 'Achternaam',
		address: 'Adres',
		postalCode: 'Postcode',
		city: 'Woonplaats',
		phone: 'Telefoonnummer (voor WhatsApp en Tikkie)',
		email: 'Email',
		personCount: 'Aantal personen',
		registrationFee: 'Inschrijfgeld',
		submit: 'Verzendje',
		waiting: 'Ee moment estebleef...',
		success: 'Danke! Dien insjrieving is verzonje.',
		error: 'Oei, d\'r ging get mis. Probeer \u2019t zoe metees nog \u2019ns.',
		rulesTitle: 'Spelregele',
		rules: [
			'Bereid de lekkerste Limburgse zoervleisj volges dien eige recept en neem dat mit nao ’t treffe.',
			'Dich meugst dien zoervleisj same mit dien gäste ope. De organisatie zörgt veur friete, appelmoes en mayo.',
			'Zorg veur genog zoervleisj veur dichzelf, dien gäste en eine kleine portie veur de jury.',
			'Hèt zoervleisj mag opgewermd waere op ein elektrisch kookstel; zorg veur ein geschikt pannetje.',
			'Ein vakjury zal de inzending beoordele.',
			'De uslag van de jury is bindend. "Neet zeivere."',
			'Uiterste aanmelddatum: 16-08-2026 of bie eine maksimaal aantal van 150 deelnemers.',
		],
	},
	nl: {
		title: 'Inschrijven',
		eventTitle: '3e oape Joabiks Zoerveisjtreff',
		eventMeta: 'Datum: 4 september 2026, start om 18:00 bij Brasserie De Maar in de wei.',
		intro: 'Vul hieronder je gegevens in om je aan te melden voor het treffen.',
		firstName: 'Voornaam',
		lastName: 'Achternaam',
		address: 'Adres',
		postalCode: 'Postcode',
		city: 'Woonplaats',
		phone: 'Telefoonnummer (voor WhatsApp en Tikkie)',
		email: 'Email',
		personCount: 'Aantal personen',
		registrationFee: 'Inschrijfgeld',
		submit: 'Versturen',
		waiting: 'Een moment alstublieft...',
		success: 'Bedankt! Je inschrijving is verzonden.',
		error: 'Er ging iets mis. Probeer het zo meteen opnieuw.',
		rulesTitle: 'Spelregels',
		rules: [
			'Bereid het lekkerste Limburgs zoervleisj volgens jouw unieke recept en neem dit mee naar het treffen.',
			'Je mag je zoervleisj samen met je gasten opeten. De organisatie zorgt voor frieten, appelmoos en mayo.',
			'Zorg voor voldoende zoervleisj voor jezelf, je gasten en een kleine portie voor de jury.',
			'Het zoervleisj kan opgewarmd worden op een elektrisch kookstel, zorg voor een geschikt pannetje.',
			'Een vakjury zal de inzending beoordelen.',
			'De uitslag van de jury is bindend. "Neet zeivere."',
			'Uiterste aanmelddatum: 16-08-2026 of bij een maximaal aantal van 150 deelnemers.',
		],
	},
}[activeLang];
---

<Layout
	lang={activeLang}
	menu={menu}
	languages={languages}
	pageTitle={content.title}
	navLabel={locale.ui.navLabel}
	languageLabel={locale.ui.languageLabel}
	brandTagline={locale.ui.brandTagline}
>
	<section class="signup-wrap">
		<div class="signup-card">
			<h1>{content.title}</h1>
			<section class="event-note" aria-label={content.eventTitle}>
				<p class="event-note-title">{content.eventTitle}</p>
				<p class="event-note-meta">{content.eventMeta}</p>
			</section>
			<p>{content.intro}</p>

			{status === 'ok' && <p class="form-status success">{content.success}</p>}
			{status === 'error' && <p class="form-status error">{content.error}</p>}

			<form class="signup-form" method="post" action="/api/signup">
				<input type="hidden" name="lang" value={activeLang} />
				<input type="text" name="website" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />

				<label for="first-name">{content.firstName}</label>
				<input id="first-name" name="firstName" type="text" autocomplete="given-name" required />

				<label for="last-name">{content.lastName}</label>
				<input id="last-name" name="lastName" type="text" autocomplete="family-name" required />

				<label for="address">{content.address}</label>
				<input id="address" name="address" type="text" autocomplete="street-address" required />

				<label for="postal-code">{content.postalCode}</label>
				<input id="postal-code" name="postalCode" type="text" autocomplete="postal-code" required />

				<label for="city">{content.city}</label>
				<input id="city" name="city" type="text" autocomplete="address-level2" required />

				<label for="email">{content.email}</label>
				<input id="email" name="email" type="email" autocomplete="email" required />

				<label for="phone">{content.phone}</label>
				<input id="phone" name="phone" type="tel" autocomplete="tel" required />

				<label for="person-count">{content.personCount}</label>
				<input id="person-count" name="personCount" type="number" min="1" step="1" inputmode="numeric" required />

				<label for="registration-fee">{content.registrationFee}</label>
				<input id="registration-fee" name="registrationFeeDisplay" type="text" readonly aria-readonly="true" />
				<input type="hidden" name="registrationFee" value="0" />

				<button type="submit" class="submit-btn">{content.submit}</button>
				<div class="loading-overlay" aria-live="polite">
					<div class="spinner"></div>
					<p>{content.waiting}</p>
				</div>
			</form>

			<section class="rules-card" aria-labelledby="rules-title">
				<h2 id="rules-title">{content.rulesTitle}</h2>
				<ul>
					{content.rules.map((rule) => <li>{rule}</li>)}
				</ul>
			</section>
		</div>
	</section>
</Layout>

<script>
	const form = document.querySelector('.signup-form') as HTMLFormElement | null;
	const submitBtn = document.querySelector('.submit-btn') as HTMLButtonElement | null;
	const loadingOverlay = document.querySelector('.loading-overlay') as HTMLDivElement | null;
	const personCountInput = document.querySelector('#person-count') as HTMLInputElement | null;
	const registrationFeeDisplay = document.querySelector('#registration-fee') as HTMLInputElement | null;
	const registrationFeeInput = document.querySelector('input[name="registrationFee"]') as HTMLInputElement | null;

	const updateRegistrationFee = () => {
		if (!personCountInput || !registrationFeeDisplay || !registrationFeeInput) {
			return;
		}

		const parsedCount = Number.parseInt(personCountInput.value, 10);
		const personCount = Number.isFinite(parsedCount) && parsedCount > 0 ? parsedCount : 0;
		const fee = personCount * 10;

		registrationFeeDisplay.value = personCount > 0 ? `€ ${fee}` : '';
		registrationFeeInput.value = String(fee);
	};

	if (form && submitBtn && loadingOverlay) {
		form.addEventListener('submit', () => {
			submitBtn.disabled = true;
			loadingOverlay.classList.add('visible');
		});
	}

	if (personCountInput) {
		personCountInput.addEventListener('input', updateRegistrationFee);
		updateRegistrationFee();
	}
</script>

<style>
	.signup-wrap {
		display: grid;
		justify-items: center;
	}

	.signup-card {
		width: min(100%, 680px);
		background: linear-gradient(180deg, #fff, #fff8f1);
		border: 1px solid rgba(159, 37, 114, 0.12);
		border-radius: 1rem;
		box-shadow: 0 10px 24px rgba(70, 19, 49, 0.08);
		padding: 1.4rem;
	}

	.signup-card h1 {
		margin: 0 0 0.5rem;
	}

	.signup-card p {
		margin: 0 0 1rem;
	}

	.event-note {
		margin: 0 0 1rem;
		padding: 0.8rem 0.9rem;
		border-radius: 0.75rem;
		background: linear-gradient(140deg, #fff7df, #ffedf7);
		border: 1px solid rgba(159, 37, 114, 0.16);
	}

	.event-note-title {
		margin: 0;
		font-weight: 800;
		color: #6a1047;
	}

	.event-note-meta {
		margin: 0.35rem 0 0;
		font-weight: 600;
	}

	.signup-form {
		display: grid;
		gap: 0.6rem;
		position: relative;
	}

	.hp {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	.form-status {
		margin: 0 0 1rem;
		padding: 0.65rem 0.8rem;
		border-radius: 0.65rem;
		font-weight: 700;
	}

	.form-status.success {
		background: #e9f8ea;
		border: 1px solid #9ad79e;
		color: #245a2a;
	}

	.form-status.error {
		background: #ffecec;
		border: 1px solid #f3a7a7;
		color: #7a1f1f;
	}

	.signup-form label {
		font-weight: 700;
		color: #4b0f34;
	}

	.signup-form input {
		font: inherit;
		padding: 0.65rem 0.75rem;
		border: 1px solid rgba(159, 37, 114, 0.25);
		border-radius: 0.6rem;
		background: #fff;
	}

	.signup-form input:focus-visible {
		outline: 2px solid rgba(159, 37, 114, 0.3);
		outline-offset: 1px;
	}

	.signup-form button {
		margin-top: 0.4rem;
		justify-self: start;
		border: 0;
		border-radius: 999px;
		padding: 0.6rem 1rem;
		font: inherit;
		font-weight: 800;
		background: #9f2572;
		color: #fff;
		cursor: pointer;
		transition: transform 0.15s ease, background 0.15s ease;
	}

	.submit-btn {
		margin-top: 0.4rem;
		justify-self: start;
		border: 0;
		border-radius: 999px;
		padding: 0.6rem 1rem;
		font: inherit;
		font-weight: 800;
		background: #9f2572;
		color: #fff;
		cursor: pointer;
		transition: transform 0.15s ease, background 0.15s ease;
	}

	.submit-btn:hover,
	.submit-btn:focus-visible {
		background: #7f1656;
		transform: translateY(-1px);
	}

	.submit-btn:disabled {
		background: #c584a5;
		cursor: not-allowed;
		transform: none;
	}

	.loading-overlay {
		display: none;
		position: absolute;
		inset: 0;
		justify-items: center;
		align-items: center;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 0.6rem;
		gap: 1rem;
		z-index: 999;
		grid-template-rows: auto auto;
	}

	.loading-overlay.visible {
		display: grid;
	}

	.loading-overlay p {
		margin: 0;
		font-weight: 700;
		color: #4b0f34;
		text-align: center;
		font-size: 0.95rem;
	}

	.rules-card {
		margin-top: 1.2rem;
		padding: 1rem 1rem 0.9rem;
		border-radius: 0.9rem;
		background: linear-gradient(135deg, #fff7ea, #fff1f8);
		border: 1px solid rgba(159, 37, 114, 0.14);
	}

	.rules-card h2 {
		margin: 0 0 0.65rem;
		font-size: 1.1rem;
		color: #4b0f34;
	}

	.rules-card ul {
		margin: 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.5rem;
	}

	.rules-card li {
		line-height: 1.5;
	}

	.spinner {
		width: 40px;
		height: 40px;
		border: 4px solid rgba(159, 37, 114, 0.2);
		border-top-color: #9f2572;
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
		justify-self: center;
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (max-width: 640px) {
		.signup-card {
			padding: 1rem;
		}
	}
</style>
