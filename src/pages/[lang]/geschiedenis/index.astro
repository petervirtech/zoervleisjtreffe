---
import Layout from '../../../layouts/Layout.astro';
import { getLocaleData } from '../../../data/site-content';

const { lang } = Astro.params;
const { activeLang, locale, menu, languages } = getLocaleData(lang);

const content = locale.pages.history;
---

<Layout
	lang={activeLang}
	menu={menu}
	languages={languages}
	pageTitle={content.title}
	navLabel={locale.ui.navLabel}
	languageLabel={locale.ui.languageLabel}
	brandTagline={locale.ui.brandTagline}
>
	<section class="history-hero">
		<p class="eyebrow">{content.intro}</p>
		<h1>{content.title}</h1>
		<p class="lead">{content.lead}</p>
		<p>{content.origin}</p>
	</section>

	<section class="timeline">
		{content.chapters.map((chapter) => (
			<article class="timeline-item">
				<div class="year-pill">{chapter.year}</div>
				<div class="chapter-card">
					<h2>{chapter.title}</h2>
					<p>{chapter.description}</p>
				</div>
			</article>
		))}
	</section>

	<section class="history-closing">
		<p>{content.closing}</p>
	</section>
</Layout>

<style>
	.history-hero,
	.chapter-card,
	.history-closing {
		border-radius: 1rem;
		background: linear-gradient(180deg, #fff, #fff8f1);
		box-shadow: 0 10px 24px rgba(70, 19, 49, 0.08);
	}

	.history-hero {
		padding: 1.5rem;
		border: 1px solid rgba(159, 37, 114, 0.1);
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.78rem;
		font-weight: 800;
		color: var(--color-secondary);
	}

	.lead {
		font-size: 1.08rem;
		font-weight: 600;
		color: rgba(110, 18, 77, 0.92);
	}

	.history-hero p {
		margin: 0;
	}

	.history-hero p + p {
		margin-top: 0.75rem;
	}

	.timeline {
		margin-top: 1.5rem;
		display: grid;
		gap: 1rem;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.85rem;
		align-items: start;
	}

	.year-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 4.4rem;
		height: 2rem;
		padding: 0 0.8rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 800;
		color: #fff;
		background: linear-gradient(135deg, rgba(159, 37, 114, 0.95), rgba(254, 153, 0, 0.9));
		box-shadow: 0 8px 20px rgba(70, 19, 49, 0.14);
	}

	.chapter-card {
		padding: 1.2rem;
		border: 1px solid rgba(159, 37, 114, 0.1);
	}

	.chapter-card h2 {
		margin: 0 0 0.5rem;
	}

	.chapter-card p {
		margin: 0;
	}

	.history-closing {
		margin-top: 1.5rem;
		padding: 1.25rem 1.4rem;
		border: 1px dashed rgba(159, 37, 114, 0.28);
		background:
			radial-gradient(circle at top right, rgba(254, 153, 0, 0.15), transparent 40%),
			linear-gradient(180deg, #fff, #fff5ea);
	}

	.history-closing p {
		margin: 0;
		font-weight: 600;
	}

	@media (max-width: 680px) {
		.timeline-item {
			grid-template-columns: 1fr;
		}

		.year-pill {
			width: fit-content;
		}
	}
</style>