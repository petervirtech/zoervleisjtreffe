---

type MenuItem = {
	href: string;
	label: string;
};

type LanguageOption = {
	href: string;
	label: string;
	code: string;
};

const {
	lang = 'lim',
	menu = [],
	languages = [],
	navLabel = 'Menu',
	languageLabel = 'Language',
	brandTagline = '',
} = Astro.props as {
	lang?: 'lim' | 'nl';
	menu?: MenuItem[];
	languages?: LanguageOption[];
	navLabel?: string;
	languageLabel?: string;
	brandTagline?: string;
};
---

<header class="site-header">
	<div class="brand-wrap">
		<a class="brand" href={`/${lang}`} aria-label="Frit-Zoervleisj Treffe">
			Frit-Zoervleisj Treffe
		</a>
		{brandTagline ? <p class="tagline">{brandTagline}</p> : null}
	</div>

	<nav aria-label={navLabel}>
		<ul class="menu">
			{menu.map((item: MenuItem) => (
				<li>
					<a href={item.href}>{item.label}</a>
				</li>
			))}
		</ul>
	</nav>

	<form class="language-switcher">
		<label class="sr-only" for="language-select">{languageLabel}</label>
		<select
			id="language-select"
			name="language"
			aria-label={languageLabel}
			onchange="if (this.value) window.location.href = this.value"
		>
			{languages.map((language: LanguageOption) => (
				<option value={language.href} selected={language.code === lang}>
					{language.label}
				</option>
			))}
		</select>
	</form>
</header>

<style>
	.site-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
		padding: 1rem 1.25rem;
		border-radius: 1.25rem;
		background: linear-gradient(135deg, rgba(159, 37, 114, 0.96), rgba(254, 153, 0, 0.92));
		color: #fffaf5;
		box-shadow: 0 18px 40px rgba(70, 19, 49, 0.18);
	}

	.brand-wrap {
		display: grid;
		gap: 0.2rem;
	}

	.brand {
		font-size: 1.15rem;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-decoration: none;
		color: inherit;
	}

	.tagline {
		margin: 0;
		font-size: 0.9rem;
		opacity: 0.88;
	}

	.menu {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.menu a {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 0.85rem;
		border-radius: 999px;
		text-decoration: none;
		color: inherit;
		font-weight: 700;
		background: rgba(255, 255, 255, 0.14);
		transition:
			transform 0.18s ease,
			background 0.18s ease;
	}

	.menu a:hover,
	.menu a:focus-visible {
		background: rgba(255, 255, 255, 0.24);
		transform: translateY(-1px);
	}

	.language-switcher {
		margin: 0;
	}

	.language-switcher select {
		min-width: 10rem;
		padding: 0.6rem 0.85rem;
		border: 0;
		border-radius: 999px;
		background: rgba(255, 250, 245, 0.95);
		color: #6e124d;
		font: inherit;
		font-weight: 700;
		box-shadow: inset 0 0 0 1px rgba(110, 18, 77, 0.08);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 720px) {
		.site-header {
			padding: 1rem;
		}

		.menu {
			width: 100%;
		}

		.language-switcher {
			width: 100%;
		}

		.language-switcher select {
			width: 100%;
		}
	}
</style>