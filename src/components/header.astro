---

type MenuItem = {
	href: string;
	label: string;
};

type LanguageOption = {
	href: string;
	label: string;
	code: 'lim' | 'nl';
};

const {
	lang = 'nl',
	menu = [],
	languages = [],
	navLabel = 'Menu',
	languageLabel = 'Language',
	brandTagline = '',
} = Astro.props as {
	lang?: 'lim' | 'nl';
	menu?: MenuItem[];
	languages?: LanguageOption[];
	navLabel?: string;
	languageLabel?: string;
	brandTagline?: string;
};

const currentPath = Astro.url.pathname;

function getLanguagePath(targetLang: 'lim' | 'nl') {
	const segments = currentPath.split('/').filter(Boolean);

	if (segments.length === 0) {
		return `/${targetLang}`;
	}

	if (segments[0] === 'lim' || segments[0] === 'nl') {
		segments[0] = targetLang;
		return `/${segments.join('/')}`;
	}

	return `/${targetLang}/${segments.join('/')}`;
}
---

<header class="site-header">
	<div class="brand-wrap">
		<a class="brand" href={`/${lang}`} aria-label="Frit-Zoervleisj Treffe">
			Frit-Zoervleisj Treffe
		</a>
		{brandTagline ? <p class="tagline">{brandTagline}</p> : null}
	</div>

	<nav class="desktop-nav" aria-label={navLabel}>
		<ul class="menu">
			{menu.map((item: MenuItem) => (
				<li>
					<a href={item.href}>{item.label}</a>
				</li>
			))}
		</ul>
	</nav>

	<form class="language-switcher">
		<fieldset>
			<legend class="sr-only">{languageLabel}</legend>
			<div class="language-flags" role="group" aria-label={languageLabel}>
				{languages.map((language: LanguageOption) => (
					<a
						href={getLanguagePath(language.code)}
						class={`flag-link ${language.code === lang ? 'is-active' : ''}`}
						aria-label={language.label}
						title={language.label}
					>
						{
							language.code === 'nl' ? (
								<svg class="flag-art" viewBox="0 0 36 24" aria-hidden="true" focusable="false">
									<rect width="36" height="8" y="0" fill="#AE1C28"></rect>
									<rect width="36" height="8" y="8" fill="#FFFFFF"></rect>
									<rect width="36" height="8" y="16" fill="#21468B"></rect>
								</svg>
							) : (
								<img class="flag-art" src="/assets/images/flg-limburg2-icon.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
							)
						}
					</a>
				))}
			</div>
		</fieldset>
	</form>

	<details class="mobile-nav">
		<summary>{navLabel}</summary>
		<ul class="mobile-menu">
			{menu.map((item: MenuItem) => (
				<li>
					<a href={item.href}>{item.label}</a>
				</li>
			))}
		</ul>
	</details>
</header>

<style>
	.site-header {
		display: grid;
		grid-template-columns: minmax(200px, 1fr) auto auto;
		align-items: center;
		gap: 0.9rem;
		width: min(100%, 860px);
		padding: 0.9rem 1.1rem;
		box-sizing: border-box;
		margin-inline: auto;
		border-radius: 1.25rem;
		background: linear-gradient(135deg, rgba(159, 37, 114, 0.96), rgba(254, 153, 0, 0.92));
		color: #fffaf5;
		box-shadow: 0 18px 40px rgba(70, 19, 49, 0.18);
		position: sticky;
		top: 0.45rem;
		z-index: 30;
		backdrop-filter: blur(4px);
	}

	.brand-wrap {
		display: grid;
		gap: 0.2rem;
		min-width: 0;
	}

	.brand {
		font-size: 1.15rem;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-decoration: none;
		color: inherit;
	}

	.tagline {
		margin: 0;
		font-size: 0.9rem;
		opacity: 0.88;
	}

	.menu {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.menu a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		padding: 0.55rem 0.95rem;
		border-radius: 999px;
		text-decoration: none;
		color: inherit;
		font-weight: 700;
		white-space: nowrap;
		background: rgba(255, 255, 255, 0.14);
		transition:
			transform 0.18s ease,
			background 0.18s ease;
	}

	.menu a:hover,
	.menu a:focus-visible {
		background: rgba(255, 255, 255, 0.24);
		transform: translateY(-1px);
	}

	.desktop-nav {
		display: block;
		min-width: 0;
		overflow: hidden;
	}

	.mobile-nav {
		display: none;
	}

	.language-switcher {
		margin: 0;
		flex-shrink: 0;
	}

	.language-switcher fieldset {
		margin: 0;
		padding: 0;
		border: 0;
	}

	.language-flags {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.28rem;
		border-radius: 999px;
		background: rgba(255, 250, 245, 0.22);
	}

	.flag-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 1.65rem;
		padding: 0.16rem;
		border-radius: 0.5rem;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.2);
		transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
	}

	.flag-link:hover,
	.flag-link:focus-visible {
		transform: translateY(-1px);
		background: rgba(255, 255, 255, 0.28);
	}

	.flag-link.is-active {
		background: rgba(255, 255, 255, 0.95);
		border-color: rgba(255, 255, 255, 0.95);
		box-shadow: 0 0 0 1px rgba(89, 26, 63, 0.15);
	}

	.flag-art {
		display: block;
		width: 100%;
		height: 100%;
		border-radius: 0.18rem;
		object-fit: contain;
		box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.18);
		overflow: hidden;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 980px) {
		.site-header {
			grid-template-columns: 1fr;
			gap: 0.85rem;
			padding: 0.95rem;
		}

		.desktop-nav {
			display: none;
		}

		.mobile-nav {
			display: block;
			border-radius: 0.8rem;
			background: rgba(255, 255, 255, 0.14);
			overflow: hidden;
		}

		.mobile-nav summary {
			cursor: pointer;
			list-style: none;
			padding: 0.8rem 0.95rem;
			font-weight: 800;
			min-height: 2.55rem;
			display: flex;
			align-items: center;
		}

		.mobile-nav summary::-webkit-details-marker {
			display: none;
		}

		.mobile-menu {
			margin: 0;
			padding: 0 0.75rem 0.75rem;
			list-style: none;
			display: grid;
			gap: 0.6rem;
		}

		.mobile-menu a {
			display: block;
			padding: 0.72rem 0.8rem;
			border-radius: 0.75rem;
			text-decoration: none;
			font-weight: 700;
			color: inherit;
			background: rgba(255, 255, 255, 0.14);
			min-height: 2.5rem;
		}

		.language-switcher,
		.language-switcher fieldset,
		.language-flags,
		.mobile-nav,
		.mobile-menu {
			width: 100%;
		}

		.language-flags {
			justify-content: center;
		}
	}

	@media (max-width: 820px) {
		.site-header {
			top: 0.35rem;
		}

		.tagline {
			font-size: 0.85rem;
		}
	}
</style>